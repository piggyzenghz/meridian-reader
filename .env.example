# Meridian environment — copy to .env, then chmod 600
# PIN gate: the password you type to enter the reader (required)
MERIDIAN_PIN=change-me
# DeepSeek API key (required for translation + summaries)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-v4-flash
MERIDIAN_PORT=3023
# hard daily cap on DeepSeek tokens — a cost guard
MERIDIAN_DAILY_TOKEN_BUDGET=3000000
# feed poll interval, minutes
MERIDIAN_FETCH_INTERVAL_MIN=30
# optional: raises the r.jina.ai rate limit used by full-text fallback
# JINA_API_KEY=jina_xxx
